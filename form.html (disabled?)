<!DOCTYPE html> 
<html lang="en"> 
<head> 
    <meta charset="UTF-8"> 
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
    <title>HCPS Interpreter Request Form</title> 
    <style> 
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; padding: 15px; background: #f1f5f9; margin: 0; } 
        .container { max-width: 450px; margin: auto; background: white; padding: 24px; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); margin-top: 20px; } 
        .logo-area { text-align: center; margin-bottom: 20px; border-bottom: 2px solid #f1f5f9; padding-bottom: 15px; } 
        .logo-area h1 { font-size: 1.3rem; margin: 0; color: #1e293b; } 
        .logo-area p { margin: 5px 0 0 0; font-size: 0.85rem; color: #64748b; } 
        label { display: block; font-weight: 500; font-size: 0.9rem; margin-top: 15px; color: #334155; } 
        input, select, textarea { width: 100%; padding: 12px; margin-top: 6px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; font-size: 1rem; background-color: #f8fafc; } 
        input:focus, select:focus { outline: none; border-color: #f39200; background-color: #fff; } 
        button { width: 100%; padding: 14px; background: #f39200; color: white; border: none; border-radius: 6px; font-size: 1rem; font-weight: 600; margin-top: 24px; cursor: pointer; transition: background 0.2s; } 
        button:hover { background: #d98200; } 
        button:disabled { background: #cbd5e1; cursor: not-allowed; }
    </style> 
</head> 
<body> 
    <div class="container"> 
        <div class="logo-area"> 
            <img src="https://www.harrisonburg.k12.va.us/images/getSchoolPicture.cfm?id=20" alt="HCPS District Logo" style="max-width:120px; margin-bottom:10px;">
            <h1>Harrisonburg City Public Schools</h1> 
            <p>Student Language Interpreter Program</p> 
        </div> 
        <h2 style="font-size: 1.15rem; margin: 0; text-align: center; color: #1e293b;">Request an Interpreter Form</h2> 
        <form id="mobileRequestForm"> 
            <label for="parentName">Your Full Name (Nombre Completo):</label> 
            <input type="text" id="parentName" placeholder="e.g., Maria Ramirez" required> 
            
            <label for="language">Language Required (Idioma):</label> 
            <select id="language" required> 
                <option value="Spanish">Spanish (Español)</option> 
                <option value="Somali">Somali (Soomaali)</option> 
                <option value="Arabic">Arabic (العربية)</option> 
                <option value="Haitian Creole">Haitian Creole (Kreyòl Ayisyen)</option> 
                <option value="Amharic">Amharic (አማርኛ)</option> 
            </select> 
            
            <label for="date">Meeting Date (Fecha de Reunión):</label> 
            <input type="date" id="date" required> 
            
            <label for="notes">Additional Information / Teacher Name:</label> 
            <textarea id="notes" rows="3" placeholder="Any optional details..."></textarea> 
            
            <button type="submit" id="submitBtn">Submit Request</button> 
        </form> 
    </div> 
    
    <script> 
        const API_URL = "https://script.google.com/macros/s/AKfycbwjccnPNoStbtifYzzD6Egb3yPgiqd8zotDH5TAqkl4i-Ys0izkWsWeZKGZOBWcRVBX/exec"; 
        
        document.getElementById('mobileRequestForm').addEventListener('submit', async (e) => { 
            e.preventDefault(); 
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerText = "Sending Request...";
            
            const payload = { 
                parentName: document.getElementById('parentName').value, 
                language: document.getElementById('language').value, 
                date: document.getElementById('date').value, 
                notes: document.getElementById('notes').value, 
                status: "Pending" 
            }; 
            
            try { 
                await fetch(API_URL, { 
                    method: 'POST', 
                    mode: 'no-cors', 
                    body: JSON.stringify(payload) 
                }); 
                
                alert("Your interpreter request has been sent to HCPS. Thank you!"); 
                document.getElementById('mobileRequestForm').reset(); 
            } catch (err) { 
                console.error(err); 
                alert("Connection error. Please try again."); 
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerText = "Submit Request";
            }
        }); 
    </script> 
</body> 
</html>
